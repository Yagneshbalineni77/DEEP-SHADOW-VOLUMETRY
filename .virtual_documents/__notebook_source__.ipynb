import os
import time
import torch
import torch.nn as nn
import torch.optim as optim
from torch.utils.data import Dataset, DataLoader, random_split
from torchvision import transforms
from torchvision.models import efficientnet_b0, EfficientNet_B0_Weights
from PIL import Image

# ==========================================
# PART 1: THE CUSTOM DATALOADER
# ==========================================
class TankShadowDataset(Dataset):
    def __init__(self, img_dir, transform=None):
        self.img_dir = img_dir
        self.transform = transform
        self.img_names = [f for f in os.listdir(img_dir) if f.endswith('.png')]

    def __len__(self):
        return len(self.img_names)

    def __getitem__(self, idx):
        img_name = self.img_names[idx]
        img_path = os.path.join(self.img_dir, img_name)
        
        # Load grayscale
        image = Image.open(img_path).convert('L') 
        if self.transform:
            image = self.transform(image)

        # Parse filename: vol_030_el_14_az_071_0119.png
        parts = img_name.replace('.png', '').split('_')
        vol_pct = float(parts[1]) / 100.0  
        elevation = float(parts[3]) / 90.0 
        
        metadata = torch.tensor([elevation], dtype=torch.float32)
        target_volume = torch.tensor([vol_pct], dtype=torch.float32)

        return image, metadata, target_volume

# ==========================================
# PART 2: THE MULTI-MODAL ARCHITECTURE
# ==========================================
class DeepShadowModel(nn.Module):
    def __init__(self):
        super(DeepShadowModel, self).__init__()
        
        # Stream A: Visual (EfficientNet)
        self.visual_backbone = efficientnet_b0(weights=EfficientNet_B0_Weights.DEFAULT)
        num_features = self.visual_backbone.classifier[1].in_features
        self.visual_backbone.classifier = nn.Identity() 
        
        self.visual_compress = nn.Sequential(
            nn.Linear(num_features, 256),
            nn.ReLU(),
            nn.Dropout(0.3)
        )

        # Stream B: Metadata (Solar Elevation)
        self.metadata_branch = nn.Sequential(
            nn.Linear(1, 16),
            nn.ReLU(),
            nn.Linear(16, 32),
            nn.ReLU()
        )

        # Fusion & Regression Head
        self.fusion_head = nn.Sequential(
            nn.Linear(256 + 32, 128),
            nn.ReLU(),
            nn.Dropout(0.2),
            nn.Linear(128, 64),
            nn.ReLU(),
            nn.Linear(64, 1),
            nn.Sigmoid() 
        )

    def forward(self, image, metadata):
        # Convert 1-channel grayscale to 3-channel for EfficientNet
        if image.shape[1] == 1:
            image = image.repeat(1, 3, 1, 1)
            
        v_features = self.visual_backbone(image)
        v_features = self.visual_compress(v_features)
        
        m_features = self.metadata_branch(metadata)
        
        fused = torch.cat((v_features, m_features), dim=1)
        volume_prediction = self.fusion_head(fused)
        
        return volume_prediction

# ==========================================
# PART 3: THE TRAINING ENGINE
# ==========================================
def main():
    # 1. Hardware Setup
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    print(f"--- INITIALIZING TRAINING ON: {device.type.upper()} ---")

    # 2. Data Preparation
    # IMPORTANT: Update this path to where Kaggle saved your dataset
    DATA_DIR = "/kaggle/input/datasets/yagneshchowdary007/oiltank/TankDataset" 
    
    # We resize to 224x224 to make EfficientNet train incredibly fast
    transform = transforms.Compose([
        transforms.Resize((224, 224)),
        transforms.ToTensor(),
    ])

    full_dataset = TankShadowDataset(img_dir=DATA_DIR, transform=transform)
    
    # 80/20 Train/Test Split
    train_size = int(0.8 * len(full_dataset))
    test_size = len(full_dataset) - train_size
    train_dataset, test_dataset = random_split(full_dataset, [train_size, test_size])

    train_loader = DataLoader(train_dataset, batch_size=32, shuffle=True)
    test_loader = DataLoader(test_dataset, batch_size=32, shuffle=False)
    
    print(f"Dataset loaded: {len(train_dataset)} Train | {len(test_dataset)} Test")

    # 3. Model, Loss, and Optimizer Initialization
    model = DeepShadowModel().to(device)
    criterion = nn.MSELoss() 
    optimizer = optim.Adam(model.parameters(), lr=0.0005)
    
    # --- THE UPGRADE: EARLY STOPPING ---
    EPOCHS = 40 
    best_val_loss = float('inf') # Set initial best loss to infinity
    patience = 5                 # How many epochs to wait before giving up
    patience_counter = 0         # Tracks how many times we failed to improve

    # 4. The Training Loop
    print(f"\n--- BEGINNING TRAINING FOR UP TO {EPOCHS} EPOCHS ---")
    for epoch in range(EPOCHS):
        model.train()
        running_loss = 0.0
        start_time = time.time()
        
        for batch_idx, (images, metadata, targets) in enumerate(train_loader):
            images, metadata, targets = images.to(device), metadata.to(device), targets.to(device)
            
            optimizer.zero_grad()
            predictions = model(images, metadata)
            loss = criterion(predictions, targets)
            
            loss.backward()
            optimizer.step()
            
            running_loss += loss.item()

        # Validation Phase
        model.eval()
        val_loss = 0.0
        with torch.no_grad():
            for images, metadata, targets in test_loader:
                images, metadata, targets = images.to(device), metadata.to(device), targets.to(device)
                predictions = model(images, metadata)
                batch_loss = criterion(predictions, targets)
                val_loss += batch_loss.item()
                
        avg_train_loss = running_loss / len(train_loader)
        avg_val_loss = val_loss / len(test_loader)
        epoch_time = time.time() - start_time
        
        print(f"Epoch [{epoch+1:02d}/{EPOCHS}] | Time: {epoch_time:.1f}s | Train Loss: {avg_train_loss:.4f} | Val Loss: {avg_val_loss:.4f}")

        # --- EARLY STOPPING LOGIC ---
        if avg_val_loss < best_val_loss:
            best_val_loss = avg_val_loss
            patience_counter = 0
            # Save the model ONLY when it gets a new high score
            torch.save(model.state_dict(), 'best_deep_shadow_weights.pth')
            print("   -> 🌟 New best model saved!")
        else:
            patience_counter += 1
            print(f"   -> No improvement. Patience: {patience_counter}/{patience}")
            
        if patience_counter >= patience:
            print(f"\n🛑 Early stopping triggered at Epoch {epoch+1}! The model stopped improving.")
            break

    print("\n--- TRAINING COMPLETE. BEST WEIGHTS SECURED ---")

# Execute the script
if __name__ == "__main__":
    main()


import os
import torch
import random
import matplotlib.pyplot as plt
from torchvision import transforms
from PIL import Image

# 1. Re-define the hardware device
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"Using device: {device.type.upper()}")

# 2. Initialize the model and load your winning weights
print("Loading the trained brain...")
model = DeepShadowModel().to(device)
model.load_state_dict(torch.load('best_deep_shadow_weights.pth'))
model.eval() # Set to evaluation mode

# 3. Grab a random image directly from your Kaggle folder
DATA_DIR = "/kaggle/input/datasets/yagneshchowdary007/oiltank/TankDataset" 
all_images = [f for f in os.listdir(DATA_DIR) if f.endswith('.png')]
random_image_name = random.choice(all_images)
image_path = os.path.join(DATA_DIR, random_image_name)

# 4. Extract the true answers from the filename (e.g., vol_030_el_14...)
parts = random_image_name.replace('.png', '').split('_')
true_vol_pct = float(parts[1]) / 100.0  
elevation = float(parts[3]) / 90.0 

# 5. Prepare the image exactly how the AI expects it
transform = transforms.Compose([
    transforms.Resize((224, 224)),
    transforms.ToTensor(),
])
image = Image.open(image_path).convert('L')
img_tensor = transform(image)

# Add the "batch" dimension and send to GPU
img_input = img_tensor.unsqueeze(0).to(device)
meta_input = torch.tensor([[elevation]], dtype=torch.float32).to(device)

# 6. Make the Prediction
with torch.no_grad():
    prediction = model(img_input, meta_input)

# 7. Convert math back to percentages
actual_pct = true_vol_pct * 100
predicted_pct = prediction.item() * 100
error = abs(actual_pct - predicted_pct)

# 8. Display the visual evidence
print(f"\n--- INFERENCE RESULTS ---")
print(f"File:             {random_image_name}")
print(f"Actual Volume:    {actual_pct:.2f}%")
print(f"Predicted Volume: {predicted_pct:.2f}%")
print(f"Margin of Error:  {error:.2f}%\n")

plt.imshow(img_tensor.squeeze().cpu(), cmap='gray')
plt.title(f"AI Prediction: {predicted_pct:.1f}% | True Volume: {actual_pct:.1f}%")
plt.axis('off')
plt.show()
